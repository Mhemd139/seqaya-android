      "paddingHorizontalDp": 20,
      "paddingBottomDp": 22
    },
    "avatar": {
      "sizeDp": 30,
      "bg": "accent.green",
      "content": "bg.cream",
      "typography": "serif/13/500"
    },
    "banner": {
      "offline": {
        "bg": "accent.brown",
        "content": "bg.cream",
        "paddingDp": { "h": 18, "v": 10 },
        "iconSizeDp": 16
      },
      "attention": {
        "bg": "accent.brownSoft",
        "border": "rgba(217,119,87,0.25)",
