{
  "$meta": {
    "name": "Seqaya Design Tokens",
    "source": "docs/design-system/source/Seqaya App.html",
    "extractedFrom": "Claude Design bundle yYdiWjOnL3SqETo1Qoen7w",
    "consumers": [
      "ui/theme/Color.kt",
      "ui/theme/Typography.kt",
      "ui/theme/Shape.kt",
      "ui/theme/Motion.kt",
      "ui/theme/Spacing.kt"
    ]
  },
  "color": {
    "light": {
      "bg": {
        "cream":        "#faf9f5",
        "creamLight":   "#e8e6dc",
        "creamLightest":"#f2f0e8"
      },
      "text": {
        "primary":   "#141413",
        "secondary": "#75736b",
        "tertiary":  "#b0aea5"
      },
      "accent": {
        "green":     "#788c5d",
        "greenSoft": "rgba(120, 140, 93, 0.12)",
        "greenInk":  "#556841",
        "brown":     "#d97757",
        "brownSoft": "rgba(217, 119, 87, 0.10)",
        "brownInk":  "#a85535",
        "blue":      "#6a9bcc"
      },
      "border": {
        "default": "#e8e6dc",
        "strong":  "#d8d6cc"
      },
      "canvas": "#ebe9e0"
    },
    "dark": {
      "bg": {
        "inkDeep": "#0d0c0b",
        "ink":     "#1a1917",
        "cream":   "#faf9f5"
      },
      "note": "Dark-mode screens invert: ink becomes cream, cream becomes near-black. Sage and terracotta lighten a touch to keep contrast. Exact dark-mode hex values for sage/terracotta are not yet in the source — to be derived from B2 · ◗, B3 · ◗, D1 · ◗, E1 · ◗ during Phase 2 theme implementation."
    }
  },
  "typography": {
    "families": {
      "serif":  "Fraunces, Iowan Old Style, Georgia, serif",
      "sans":   "Inter, -apple-system, system-ui, sans-serif",
      "mono":   "JetBrains Mono, ui-monospace, monospace"
    },
    "fraunces": {
      "axes": {
        "weight": [400, 500, 600],
        "opsz":   [9, 14, 24, 36, 72, 96, 144],
        "italic": [0, 1]
      },
      "note": "Variable font. opsz values are deliberate per-scale: display uses 144, headings 24–72, body/inline 14."
    },
    "scale": {
      "displayXL": {
        "font": "serif",
        "sizeSp": 72,
        "weight": 500,
        "lineHeight": 0.95,
        "letterSpacingEm": -0.03,
        "opsz": 144,
        "variantNumeric": "tabular-nums",
        "usage": "Hero number on Device Detail (moisture 62%)."
      },
      "displayL": {
        "font": "serif",
        "sizeSp": 48,
        "weight": 500,
        "lineHeight": 0.95,
        "letterSpacingEm": -0.02,
        "opsz": 72,
        "variantNumeric": "tabular-nums",
        "usage": "Card-level moisture number (num-card)."
      },
      "hXL": {
        "font": "serif",
        "sizeSp": 34,
        "weight": 500,
        "lineHeight": 1.08,
        "letterSpacingEm": -0.02,
        "opsz": 72,
        "usage": "Page titles (Home empty, Delete account)."
      },
      "hL": {
        "font": "serif",
        "sizeSp": 26,
        "weight": 500,
        "lineHeight": 1.12,
        "letterSpacingEm": -0.015,
        "opsz": 36,
        "usage": "Section titles (Library rails, Plant detail name)."
      },
      "hM": {
        "font": "serif",
        "sizeSp": 20,
        "weight": 500,
        "lineHeight": 1.2,
        "letterSpacingEm": -0.01,
        "opsz": 24,
        "usage": "Device card name, Plant detail subsections."
      },
      "bodyLg": {
        "font": "sans",
        "sizeSp": 15,
        "weight": 400,
        "lineHeight": 1.55,
        "usage": "Sign-in lede, card body."
      },
      "body": {
        "font": "sans",
        "sizeSp": 14,
        "weight": 400,
        "lineHeight": 1.55,
        "usage": "Body copy (spec minimum is 14sp; global rule says body ≥ 16sp — reconcile in Phase 2 by bumping base body to 16sp and treating 14sp as the secondary/caption tier)."
      },
      "caption": {
        "font": "sans",
        "sizeSp": 13,
        "weight": 500,
        "lineHeight": 1.5,
        "usage": "Card metadata (last watered, seen)."
      },
      "fine": {
        "font": "sans",
        "sizeSp": 12,
        "weight": 400,
        "lineHeight": 1.5,
        "color": "text.tertiary",
        "usage": "Legal fine print, 'Target 60%'."
      },
      "labelCaps": {
        "font": "mono",
        "sizeSp": 10,
        "weight": 400,
        "letterSpacingEm": 0.16,
        "textTransform": "uppercase",
        "color": "text.secondary",
        "usage": "Section eyebrows, field labels, step counters."
      },
      "wordmark": {
        "font": "serif",
        "sizeSp": 18,
        "weight": 500,
        "letterSpacingEm": -0.01,
        "opsz": 14,
        "usage": "Top-bar brand mark."
      }
    }
  },
  "shape": {
    "radiusDp": {
      "xs":  8,
      "sm":  10,
      "md":  14,
      "lg":  16,
      "xl":  20,
      "xxl": 24,
      "pill": 100,
      "phone": 34,
      "phoneOuter": 44
    },
    "usage": {
      "button":       "md (14)",
      "input":        "md (14)",
      "card":         "xl (20)",
      "sheetTop":     "xxl (24)",
      "dsSection":    "xxl (24)",
      "chip":         "pill",
      "innerTile":    "lg (16)",
      "photoFrame":   "lg (18 in source, use xl=20 at implementation)"
    }
  },
  "spacing": {
    "scale": {
      "none": 0,
      "xxs":  4,
      "xs":   8,
      "sm":   10,
      "md":   12,
      "lg":   14,
      "xl":   16,
      "xxl":  20,
      "xxxl": 24,
      "huge": 32
    },
    "semantic": {
      "pageHorizontal":  20,
      "pageTopSafe":     14,
      "cardPadding":     20,
      "cardGap":         14,
      "sectionGap":      22,
      "formFieldGap":    18,
      "inlineIconGap":   10,
      "buttonGapInline": 10
    }
  },
  "components": {
    "button": {
      "heightDp": 52,
      "radiusDp": 14,
      "paddingHorizontalDp": 20,
      "iconGapDp": 10,
      "variants": {
        "primary":   { "bg": "accent.brown",   "content": "bg.cream" },
        "resume":    { "bg": "accent.green",   "content": "bg.cream", "note": "Used only on Resume watering (G4)." },
        "secondary": { "bg": "transparent",    "content": "text.primary", "border": "border.strong" },
        "text":      { "bg": "transparent",    "content": "accent.brown", "underline": true, "weight": 500 },
        "disabled":  { "bg": "bg.creamLight",  "content": "text.tertiary" }
      },
      "touchTargetMinDp": 44
    },
    "chip": {
      "paddingHorizontalDp": 11,
      "paddingVerticalDp":   6,
      "radiusDp": "pill",
      "typography": "sans/12/500",
      "variants": {
        "default": { "bg": "bg.creamLight",    "content": "text.primary" },
        "active":  { "bg": "text.primary",     "content": "bg.cream" },
        "green":   { "bg": "accent.greenSoft", "content": "accent.greenInk" },
        "brown":   { "bg": "accent.brownSoft", "content": "accent.brownInk" }
      }
    },
    "statusDot": {
      "sizeDp": 7,
      "variants": {
        "green": "accent.green",
        "brown": "accent.brown",
        "gray":  "text.tertiary"
      },
      "rule": "Color is never the sole signal. Always pair with a text label."
    },
    "card": {
      "bg": "bg.creamLightest",
      "border": "border.default",
      "borderWidthDp": 1,
      "radiusDp": 20,
      "paddingDp": 20
    },
    "field": {
      "background": "transparent",
      "borderBottom": { "color": "border.strong", "widthDp": 1 },
      "paddingVerticalDp": 12,
      "labelStyle": "labelCaps",
      "valueStyle": "bodyLg"
    },
    "divider": {
      "color": "border.default",
      "widthDp": 1,
      "verticalMarginDp": 14
    },
    "topBar": {
      "heightDp": 56,
      "paddingHorizontalDp": 20,
      "titleStyle": "serif/16/500",
      "iconButtonDp": 36
    },
    "bottomTabs": {
      "heightDp": 56,
      "tabs": ["home", "scan", "library"],
      "borderTop": { "color": "border.default", "widthDp": 1 },
      "labelStyle": "mono/9.5/uppercase/0.1em",
      "activeColor": "text.primary",
      "inactiveColor": "text.tertiary"
    },
    "sheet": {
      "topRadiusDp": 24,
      "borderTop": { "color": "border.strong", "widthDp": 1 },
      "handle": { "widthDp": 40, "heightDp": 4, "color": "text.tertiary" },
      "paddingHorizontalDp": 20,
      "paddingBottomDp": 22
    },
    "avatar": {
      "sizeDp": 30,
      "bg": "accent.green",
      "content": "bg.cream",
      "typography": "serif/13/500"
    },
    "banner": {
      "offline": {
        "bg": "accent.brown",
        "content": "bg.cream",
        "paddingDp": { "h": 18, "v": 10 },
        "iconSizeDp": 16
      },
      "attention": {
        "bg": "accent.brownSoft",
        "border": "rgba(217,119,87,0.25)",
        "content": "accent.brownInk",
        "radiusDp": 14,
        "paddingDp": { "h": 14, "v": 10 }
      }
    },
    "toast": {
      "bg": "text.primary",
      "content": "bg.cream",
      "radiusDp": "pill",
      "paddingDp": { "h": 18, "v": 10 }
    }
  },
  "iconography": {
    "style": "Custom hand-feel SVG set (NOT Heroicons, NOT Lucide, NOT Material Symbols)",
    "viewBox": "24 24",
    "strokeWidth": 1.5,
    "strokeLinecap": "round",
    "strokeLinejoin": "round",
    "defaultSizeDp": 22,
    "set": [
      "leaf", "drop", "sun", "thermo", "wind", "pot", "phoneTap", "device",
      "chart", "search", "settings", "user", "plus", "close", "back", "eye",
      "check", "alert", "trash", "bookmark", "share", "more", "flash", "flip",
      "gallery", "home", "homeFill", "scan", "scanFill", "book", "bookFill"
    ],
    "marks": ["LeafMark (breathing, 2.2s)", "PlantSketch (fig, monstera, pothos, snake, basil, mint, rosemary, succulent, orchid)"],
    "contextualIllustrations": ["ClosedBud", "OpeningLeaf", "WateringCan"],
    "source": "docs/design-system/source/seqaya-icons.jsx and seqaya-screens-nfc.jsx"
  },
  "motion": {
    "ease": "cubic-bezier(0.2, 0.8, 0.2, 1)",
    "durationsMs": {
      "micro":  180,
      "state":  260,
      "screen": 420
    },
    "named": {
      "leafBreathe": { "keyframes": "scale 1 → 1.04 → 1, opacity 0.9 → 1 → 0.9", "durationMs": 2200, "loop": true },
      "nfcWave":     { "keyframes": "size 40 → 170, opacity 0.9 → 0", "durationMs": 2400, "delaysMs": [0, 300, 600], "loop": true },
      "orbitLoader": { "durationMs": 8000, "linear": true, "loop": true }
    },
    "reducedMotion": {
      "rule": "When LocalAccessibilityManager reports reduced motion, disable leafBreathe/nfcWave/orbitLoader animations and render their final static state. No springs, no bounces globally."
    }
  },
  "surfaces": {
    "canvas":       "#ebe9e0",
    "phoneBezel":   "#2a2825",
    "phoneBezelDark":"#0d0c0b",
    "grain": {
      "opacity": 0.35,
      "blendMode": "multiply",
      "note": "SVG fractalNoise at baseFrequency 0.9, 2 octaves. In Compose, use a tiled noise drawable at 35% alpha with multiply blend on the cream surface."
    }
  },
  "rules": {
    "colorUsage": [
      "Cream does the work. Sage and terracotta only speak when they have something to say.",
      "Terracotta = primary CTA, warnings, errors, deletion.",
      "Sage = healthy state, confident match, resume-watering CTA, success.",
      "Fog blue = reserved for future quiet-neutral accents; not currently used in any screen."
    ],
    "elevation": "Hairlines over shadows. The only shadow in the system is the phone frame itself — UI surfaces use borders, not elevation.",
    "gradients": "None in the UI. The camera screen uses a subtle radial only because it represents a viewfinder, not a surface.",
    "glassmorphism": "Forbidden.",
    "emojiIcons": "Forbidden. Use the SVG set only."
  }
}
