  "typography": {
    "families": {
      "serif":  "Fraunces, Iowan Old Style, Georgia, serif",
      "sans":   "Inter, -apple-system, system-ui, sans-serif",
      "mono":   "JetBrains Mono, ui-monospace, monospace"
    },
    "fraunces": {
      "axes": {
        "weight": [400, 500, 600],
        "opsz":   [9, 14, 24, 36, 72, 96, 144],
        "italic": [0, 1]
      },
      "androidLoading": {
        "format": "Variable TTF",
        "files": ["Fraunces[SOFT,WONK,opsz,wght].ttf", "Fraunces-Italic[SOFT,WONK,opsz,wght].ttf"],
        "location": "app/src/main/res/font/",
        "minSdk": 26,
        "composeApi": "FontVariation.Setting(\"opsz\", <value>), FontVariation.Setting(\"wght\", <value>)",
        "decision": "Ship the variable TTF. Android 26+ supports variable fonts natively via FontVariation; min SDK matches. No static-cut fallback needed.",
        "source": "Decision made 2026-04-18 based on seqaya-design-prompt.md line 315 + Android platform docs."
      },
      "opszUsage": {
        "14": "Inline serif (wordmark, small italic asides)",
        "24": "hM (20sp headings — device card names, plant-detail subsections)",
        "36": "hL (26sp — section titles, identity card state ribbon values)",
        "72": "hXL (34sp page titles) + displayL (48sp card numbers)",
        "96": "IdentityCard nickname (38sp) — single-purpose value from seqaya-screens-nfc.jsx",
        "144": "displayXL (72sp hero number on device detail)"
      }
    },
    "scale": {
      "displayXL": {
        "font": "serif",
        "sizeSp": 72,
        "weight": 500,
        "lineHeight": 0.95,
        "letterSpacingEm": -0.03,
        "opsz": 144,
        "variantNumeric": "tabular-nums",
        "usage": "Hero number on Device Detail (moisture 62%)."
      },
      "displayL": {
        "font": "serif",
        "sizeSp": 48,
        "weight": 500,
        "lineHeight": 0.95,
        "letterSpacingEm": -0.02,
        "opsz": 72,
        "variantNumeric": "tabular-nums",
        "usage": "Card-level moisture number (num-card)."
      },
      "hXL": {
        "font": "serif",
        "sizeSp": 34,
        "weight": 500,
        "lineHeight": 1.08,
        "letterSpacingEm": -0.02,
        "opsz": 72,
        "usage": "Page titles (Home empty, Delete account)."
      },
      "hL": {
        "font": "serif",
        "sizeSp": 26,
        "weight": 500,
        "lineHeight": 1.12,
        "letterSpacingEm": -0.015,
        "opsz": 36,
        "usage": "Section titles (Library rails, Plant detail name)."
      },
      "hM": {
        "font": "serif",
        "sizeSp": 20,
        "weight": 500,
        "lineHeight": 1.2,
        "letterSpacingEm": -0.01,
        "opsz": 24,
        "usage": "Device card name, Plant detail subsections."
      },
      "body": {
        "font": "sans",
        "sizeSp": 16,
        "weight": 400,
        "lineHeight": 1.55,
        "letterSpacingEm": 0,
        "usage": "Default body copy. Per design prompt and global accessibility rule, body is 16sp minimum on mobile."
      },
      "bodySecondary": {
        "font": "sans",
        "sizeSp": 15,
        "weight": 400,
        "lineHeight": 1.55,
        "usage": "Slightly tighter body for dense card interiors (sign-in lede, device-card stats). Use only when 16sp would wrap awkwardly in a small card — not as default body."
      },
      "caption": {
        "font": "sans",
        "sizeSp": 13,
        "weight": 500,
        "lineHeight": 1.5,
        "usage": "Card metadata (last watered, seen). This is the 'label / caption' size from the design prompt."
      },
      "fine": {
        "font": "sans",
        "sizeSp": 12,
        "weight": 400,
        "lineHeight": 1.5,
        "color": "text.tertiary",
        "usage": "Legal fine print, 'Target 60%', 'We never store your password.'"
      },
      "labelCaps": {
        "font": "mono",
        "sizeSp": 10,
        "weight": 400,
        "letterSpacingEm": 0.16,
        "textTransform": "uppercase",
