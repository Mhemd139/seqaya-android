      "typography": "sans/12/500",
      "variants": {
        "default": { "bg": "bg.creamLight",    "content": "text.primary" },
        "active":  { "bg": "text.primary",     "content": "bg.cream" },
        "green":   { "bg": "accent.greenSoft", "content": "accent.greenInk" },
        "brown":   { "bg": "accent.brownSoft", "content": "accent.brownInk" }
      }
    },
