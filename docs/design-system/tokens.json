  "components": {
    "button": {
      "heightDp": 56,
      "radiusDp": 14,
      "paddingHorizontalDp": 20,
      "iconGapDp": 10,
      "variants": {
        "primary":   { "bg": "accent.green",   "content": "bg.cream" },
        "destructive": { "bg": "accent.brown", "content": "bg.cream", "note": "Warnings, errors, deletion, attention CTAs." },
        "secondary": { "bg": "transparent",    "content": "text.primary", "border": "border.strong" },
        "text":      { "bg": "transparent",    "content": "accent.brown", "underline": true, "weight": 500 },
        "disabled":  { "bg": "bg.creamLight",  "content": "text.tertiary" }
      },
      "touchTargetMinDp": 44
    },
    "chip": {
      "paddingHorizontalDp": 11,
      "paddingVerticalDp":   6,
