      "bg": "text.primary",
      "content": "bg.cream",
      "radiusDp": "pill",
      "paddingDp": { "h": 18, "v": 10 }
    }
  },
  "iconography": {
    "style": "Custom hand-feel SVG set (NOT Heroicons, NOT Lucide, NOT Material Symbols)",
    "viewBox": "24 24",
    "strokeWidth": 1.5,
    "strokeLinecap": "round",
    "strokeLinejoin": "round",
    "defaultSizeDp": 22,
    "set": [
      "leaf", "drop", "sun", "thermo", "wind", "pot", "phoneTap", "device",
      "chart", "search", "settings", "user", "plus", "close", "back", "eye",
      "check", "alert", "trash", "bookmark", "share", "more", "flash", "flip",
      "gallery", "home", "homeFill", "scan", "scanFill", "book", "bookFill"
    ],
    "marks": ["LeafMark (breathing, 2.2s)", "PlantSketch (fig, monstera, pothos, snake, basil, mint, rosemary, succulent, orchid)"],
    "contextualIllustrations": ["ClosedBud", "OpeningLeaf", "WateringCan"],
    "source": "docs/design-system/source/seqaya-icons.jsx and seqaya-screens-nfc.jsx"
  },
  "motion": {
    "ease": "cubic-bezier(0.2, 0.8, 0.2, 1)",
    "durationsMs": {
      "micro":  180,
      "state":  260,
      "screen": 420
    },
    "named": {
      "leafBreathe": { "keyframes": "scale 1 → 1.04 → 1, opacity 0.9 → 1 → 0.9", "durationMs": 2200, "loop": true },
      "nfcWave":     { "keyframes": "size 40 → 170, opacity 0.9 → 0", "durationMs": 2400, "delaysMs": [0, 300, 600], "loop": true },
      "orbitLoader": { "durationMs": 8000, "linear": true, "loop": true }
    },
    "reducedMotion": {
      "rule": "When LocalAccessibilityManager reports reduced motion, disable leafBreathe/nfcWave/orbitLoader animations and render their final static state. No springs, no bounces globally."
    }
  },
  "surfaces": {
    "canvas":       "#ebe9e0",
    "phoneBezel":   "#2a2825",
    "phoneBezelDark":"#0d0c0b",
    "grain": {
      "targetOpacity": 0.02,
      "blendMode": "multiply",
      "source": "seqaya-design-prompt.md line 353: '2% opacity paper-grain noise overlay'. The 35% value in the HTML is a display artifact of the CSS mix-blend stack, not the spec.",
      "androidImplementation": {
        "decision": "Pre-rendered tileable PNG at 2% alpha with multiply blend over the cream surface.",
        "rationale": "Load-bearing to the editorial warmth aesthetic (design forbids flat fills), but static — a tile has zero runtime cost and no shader complexity. Compose shaders are overkill for a non-animated texture.",
        "asset": "app/src/main/res/drawable-nodpi/paper_grain.png",
        "assetSpec": {
          "size": "180x180 px",
          "generation": "SVG fractalNoise baseFrequency 0.9, numOctaves 2, colorMatrix 0.08 0.08 0.07 → rasterize to PNG, then set alpha channel to 2% globally",
          "tileMode": "BitmapShader.TileMode.REPEAT",
          "composition": "drawBehind on the root Scaffold surface with BlendMode.Multiply over the cream background"
        },
        "reducedMotionNote": "Static texture — no motion concerns."
      }
    }
  },
  "rules": {
    "colorUsage": [
      "Cream does the work. Sage and terracotta only speak when they have something to say.",
      "Sage = primary CTA, healthy state, confident match, success.",
      "Terracotta = warnings, errors, deletion, thirsty-device attention.",
      "Fog blue = reserved for future quiet-neutral accents; not currently used in any screen."
    ],
    "elevation": "Hairlines over shadows. The only shadow in the system is the phone frame itself — UI surfaces use borders, not elevation.",
    "gradients": "None in the UI. The camera screen uses a subtle radial only because it represents a viewfinder, not a surface.",
    "glassmorphism": "Forbidden.",
    "emojiIcons": "Forbidden. Use the SVG set only."
  }
}
