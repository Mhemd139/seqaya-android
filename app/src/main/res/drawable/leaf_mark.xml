<?xml version="1.0" encoding="utf-8"?>
<!--
  Splash icon. Identical paths and rendering to ic_launcher_foreground so
  the Android 12+ icon-to-splash morph hands off with no visual change.
  Larger viewport for splash rendering at ~240dp; same 108-unit coordinate
  space so the leaf positions match across all uses.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="288dp"
    android:height="288dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:name="leaf_outline"
        android:pathData="M26,82 C31.6,51.3 48.4,28.7 82,26 C79.2,56.7 65.2,77.7 26,82 Z"
        android:strokeColor="#788C5D"
        android:strokeWidth="3.4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <path
        android:name="leaf_midrib"
        android:pathData="M26,82 C40,70.3 54,60.7 73.6,40.7"
        android:strokeColor="#788C5D"
        android:strokeWidth="3.4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />

    <path
        android:name="leaf_vein"
        android:pathData="M42.8,72.7 C48.4,70.3 54,69.2 59.6,69.2"
        android:strokeColor="#788C5D"
        android:strokeWidth="3.4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>
