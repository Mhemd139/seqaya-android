<?xml version="1.0" encoding="utf-8"?>
<!--
  Monochrome layer for Android 13+ themed icons. The system tints this with
  the user's wallpaper-derived theme colour; without it, Android auto-
  generates one from the foreground and the result is unpredictable.

  Filled silhouette, single colour. Strokes against a system-tinted
  background read as visual noise, so this layer uses a fill of the leaf
  shape rather than mirroring the line-art foreground.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <path
        android:pathData="M26,82 C31.6,51.3 48.4,28.7 82,26 C79.2,56.7 65.2,77.7 26,82 Z"
        android:fillColor="#788C5D" />
</vector>
